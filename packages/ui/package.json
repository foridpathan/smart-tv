{
  "name": "@smart-tv/ui",
  "version": "0.0.1",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./*": "./dist/*.js"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*.d.ts",
        "dist/index.d.ts"
      ]
    }
  },
  "license": "MIT",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "build:components": "tsc",
    "check-types": "tsc --noEmit",
    "dev:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "dev:components": "tsc --watch",
    "lint": "eslint src --max-warnings 0"
  },
  "peerDependencies": {
    "react": "^18"
  },
  "devDependencies": {
    "@smart-tv/core": "workspace:*",
    "@smart-tv/eslint-config": "workspace:*",
    "@smart-tv/tailwind-config": "workspace:*",
    "@smart-tv/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.1.5",
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.1.0",
    "eslint": "^9.33.0",
    "tailwindcss": "^4.1.5",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "lodash": "^4.17.21"
  }
}
